# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------

APP_ENV=local
APP_URL=http://localhost/benehom
SESSION_IDLE_TIMEOUT=1800

NUMA_ENABLED=false
NUMA_MAX_MESSAGE_LENGTH=300
NUMA_DAILY_LIMIT=5
NUMA_MONTHLY_LIMIT=20
NUMA_RESERVATION_TTL_SECONDS=120

# Production example:
# APP_ENV=production
# APP_URL=https://benehom.es


# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------

DB_HOST=localhost
DB_PORT=3306
DB_NAME=your_database_name
DB_USER=your_database_user
DB_PASS=your_database_password

# Testing:
# phpunit.xml forces DB_NAME=benehom_test.
# DB_HOST, DB_PORT, DB_USER and DB_PASS can be overridden by the environment.


# -----------------------------------------------------------------------------
# SMTP / transactional email
# -----------------------------------------------------------------------------

SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_SECURE=ssl
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
SMTP_FROM=your-email@example.com
SMTP_FROM_NAME=BeneHom

# Hostinger Email production example:
# SMTP_HOST=smtp.hostinger.com
# SMTP_PORT=465
# SMTP_SECURE=ssl
# SMTP_USER=support@benehom.es
# SMTP_FROM=support@benehom.es
# SMTP_FROM_NAME=BeneHom
