DB_HOST=localhost
DB_PORT=3307
DB_NAME=nombre_base_datos
DB_USER=usuario_bd
DB_PASS=contraseña_bd

# Local: mantener .env editable por el usuario de desarrollo.

# Si Apache/PHP necesita leerlo como www-data, usar una opción práctica:

# sudo chown hiram9112:www-data .env && chmod 640 .env

# Producción/Hostinger: .env debe estar fuera de la raíz pública, con permisos estrictos,

# preferiblemente 600, y propietario igual al usuario efectivo que ejecuta PHP.


# Testing: phpunit.xml fuerza DB_NAME=benehom_test.
# DB_HOST, DB_PORT, DB_USER y DB_PASS pueden sobreescribirse desde el entorno local.

APP_ENV=local
SESSION_IDLE_TIMEOUT=1800


SMTP_USER=user_smtp
SMTP_PASS=contraseña_

APP_URL=https://benehom.es
